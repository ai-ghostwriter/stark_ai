{
  "servers": [
    {
      "name": "mcp-os",
      "command": "npm",
      "args": ["--silent", "run", "dev"],
      "cwd": "../../tools/mcp-os",
      "timeoutMs": 10000,
      "retryBackoffMs": 100
    },
    {
      "name": "mcp-files",
      "command": "npm",
      "args": ["--silent", "run", "dev"],
      "cwd": "../../tools/mcp-files",
      "timeoutMs": 10000,
      "retryBackoffMs": 100
    },
    {
      "name": "mcp-web",
      "command": "npm",
      "args": ["--silent", "run", "dev"],
      "cwd": "../../tools/mcp-web",
      "timeoutMs": 10000,
      "retryBackoffMs": 100
    },
    {
      "name": "mcp-screen",
      "command": ".venv/bin/python",
      "args": ["src/server.py"],
      "cwd": "../../tools/mcp-screen",
      "timeoutMs": 15000,
      "retryBackoffMs": 100
    },
    {
      "name": "mcp-productivity",
      "command": "npm",
      "args": ["--silent", "run", "dev"],
      "cwd": "../../tools/mcp-productivity",
      "timeoutMs": 10000,
      "retryBackoffMs": 100
    },
    {
      "name": "mcp-dev",
      "command": "npm",
      "args": ["--silent", "run", "dev"],
      "cwd": "../../tools/mcp-dev",
      "timeoutMs": 10000,
      "retryBackoffMs": 100
    }
  ]
}
